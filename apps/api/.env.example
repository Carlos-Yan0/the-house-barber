# =============================================
# The House Barber - API Environment Variables
# =============================================

# Server
PORT=3333
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"

# CORS (comma-separated origins)
CORS_ORIGIN="http://localhost:5173,https://your-app.vercel.app"

# Self URL for keep-alive (production)
API_URL="https://your-api.onrender.com"

# Mercado Pago (optional - for PIX)
MP_ACCESS_TOKEN="TEST-your-mercado-pago-access-token"
MP_WEBHOOK_SECRET="your-webhook-secret"
